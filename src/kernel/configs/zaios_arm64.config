# ZAIos kernel config — ARM64 (AArch64) — Raspberry Pi 4/5, Odroid, etc.
# Inherits from zaios_common.config (concatenated by build.sh)

# ── 64-bit ARM ───────────────────────────────────────────────────────────────
CONFIG_ARM64=y
CONFIG_64BIT=y
CONFIG_MMU=y
CONFIG_ARCH_MMAP_RND_BITS=18
CONFIG_ARCH_MMAP_RND_BITS_MIN=18
CONFIG_ARCH_MMAP_RND_BITS_MAX=33
CONFIG_ARCH_MMAP_RND_COMPAT_BITS=11
CONFIG_ARCH_MMAP_RND_COMPAT_BITS_MIN=11
CONFIG_ARCH_MMAP_RND_COMPAT_BITS_MAX=16
CONFIG_STACKTRACE_SUPPORT=y
CONFIG_ILLEGAL_POINTER_VALUE=0xdead000000000000
CONFIG_LOCKDEP_SUPPORT=y
CONFIG_TRACE_IRQFLAGS_SUPPORT=y
CONFIG_GENERIC_BUG=y
CONFIG_GENERIC_BUG_RELATIVE_POINTERS=y
CONFIG_GENERIC_HWEIGHT=y
CONFIG_GENERIC_CSUM=y
CONFIG_GENERIC_CALIBRATE_DELAY=y
CONFIG_SMP=y
CONFIG_NR_CPUS=256
CONFIG_HOTPLUG_CPU=y
CONFIG_ARCH_PROC_KCORE_TEXT=y

# ── Page size ────────────────────────────────────────────────────────────────
CONFIG_ARM64_4K_PAGES=y
CONFIG_ARM64_VA_BITS=39
CONFIG_ARM64_VA_BITS_MIN=39
CONFIG_ARM64_PA_BITS=48

# ── CPUFreq ──────────────────────────────────────────────────────────────────
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_GOV_PERFORMANCE=y
CONFIG_CPU_FREQ_GOV_ONDEMAND=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_ARM_SCPI_CPUFREQ=y
CONFIG_ARM_SCMI_CPUFREQ=y
CONFIG_ARM_BCM2835_CPUFREQ=y          # Raspberry Pi

# ── Raspberry Pi 4/5 ─────────────────────────────────────────────────────────
CONFIG_ARCH_BCM=y
CONFIG_ARCH_BCM2835=y
CONFIG_BCM2835_MBOX=y
CONFIG_RASPBERRYPI_FIRMWARE=y
CONFIG_RASPBERRYPI_POWER=y
CONFIG_PWM_BCM2835=y
CONFIG_BCM2711_THERMAL=y
CONFIG_BCM2712_THERMAL=y
CONFIG_SERIAL_BCM63XX=y
CONFIG_SERIAL_AMBA_PL011=y
CONFIG_SERIAL_AMBA_PL011_CONSOLE=y
CONFIG_BCM2835_WDT=y
CONFIG_HW_RANDOM_BCM2835=y
CONFIG_BCM_VCIO=y
CONFIG_BCM2835_VCHIQ=y
CONFIG_BCM2835_VCHIQ_MMAL=y

# ── Other popular ARM64 boards ───────────────────────────────────────────────
CONFIG_ARCH_ROCKCHIP=y                 # Odroid, Pinebook, many TV boxes
CONFIG_ROCKCHIP_PM_DOMAINS=y
CONFIG_PCIE_ROCKCHIP_DW_HOST=y
CONFIG_PHY_ROCKCHIP_PCIE=y
CONFIG_NVIDIA_CORESIGHT=y
CONFIG_ARCH_MESON=y                    # Amlogic TV boxes
CONFIG_ARCH_QCOM=y                     # Snapdragon TV sticks
CONFIG_ARCH_SUNXI=y                    # Allwinner
CONFIG_ARCH_ZYNQMP=y
CONFIG_ARCH_LAYERSCAPE=y
CONFIG_ARCH_TEGRA=y                    # Jetson

# ── EFI on ARM64 ─────────────────────────────────────────────────────────────
CONFIG_EFI=y
CONFIG_EFI_STUB=y
CONFIG_EFI_PARAMS_FROM_FDT=y
CONFIG_EFI_RUNTIME_WRAPPERS=y
CONFIG_EFI_ARMSTUB_DTB_LOADER=y
CONFIG_EFI_BOOTLOADER_CONTROL=y

# ── PCI ──────────────────────────────────────────────────────────────────────
CONFIG_PCI_HOST_GENERIC=y
CONFIG_PCIE_DW=y
CONFIG_PCIE_DW_HOST=y

# ── Clocksource / timer ──────────────────────────────────────────────────────
CONFIG_ARM_ARCH_TIMER=y
CONFIG_ARM_ARCH_TIMER_EVTSTREAM=y
CONFIG_ARM_TIMER_SP804=y
CONFIG_CLKSRC_MMIO=y

# ── DRM / GPU ────────────────────────────────────────────────────────────────
# (common.config already enables DRM_VC4 / DRM_V3D — that's the Pi GPU)
CONFIG_DRM_PANEL_ILITEK_ILI9881C=y
CONFIG_DRM_PANEL_RASPBERRYPI_TOUCHSCREEN=y
CONFIG_DRM_LIMA=y                       # Mali-4xx (Bifrost, Utgard)
CONFIG_DRM_PANFROST=y                   # Mali Midgard+
CONFIG_DRM_MSM=y                        # Adreno (Snapdragon TV sticks)
CONFIG_DRM_PANEL_SAMSUNG_LD9040=y
CONFIG_DRM_PANEL_LG_LB035QV02=y
CONFIG_DRM_PANEL_LG_LG4573=y

# ── ARM-specific DMA / IOMMU ─────────────────────────────────────────────────
CONFIG_IOMMU_SUPPORT=y
CONFIG_IOMMU_IO_PGTABLE_LPAE=y
CONFIG_ARM_SMMU=y
CONFIG_ARM_SMMU_V3=y
CONFIG_ROCKCHIP_IOMMU=y

# ── Thermal / Power ──────────────────────────────────────────────────────────
CONFIG_THERMAL=y
CONFIG_THERMAL_OF=y
CONFIG_CPU_THERMAL=y
CONFIG_ROCKCHIP_THERMAL=y
CONFIG_BCM2835_THERMAL=y
CONFIG_DOVE_THERMAL=y
CONFIG_ARMADA_THERMAL=y
CONFIG_WATCHDOG=y
CONFIG_WATCHDOG_NOWAYOUT=y
CONFIG_ARM_SP805_WATCHDOG=y
CONFIG_BCM7038_WDT=y
CONFIG_MEDIATEK_WATCHDOG=y
CONFIG_RTD119X_WATCHDOG=y

# ── Compat (run 32-bit ARM binaries) ─────────────────────────────────────────
CONFIG_COMPAT=y
CONFIG_ARM64_32=y

# ── Realtek / Amlogic specifics ──────────────────────────────────────────────
CONFIG_ARCH_REALTEK=y
CONFIG_ARCH_RTD16XX=y
CONFIG_RTD16XX_WATCHDOG=y
