CONFIG_ATA=y
CONFIG_CDROM=y
CONFIG_SCSI=y
CONFIG_BLK_DEV_SD=y
CONFIG_BLK_DEV_SR=y
CONFIG_CHR_DEV_SG=y
# CRITICAL: Loop device support — needed to mount the squashfs FILE inside
# the ISO9660 filesystem. Without this, mount fails with
# "can't setup loop device: No such device or address"
CONFIG_BLK_DEV_LOOP=y
CONFIG_BLK_DEV_LOOP_MIN_COUNT=8
CONFIG_SATA_AHCI=y
CONFIG_SATA_AHCI_PLATFORM=y
CONFIG_SATA_NV=y
CONFIG_SATA_SIL=y
CONFIG_SATA_SIS=y
CONFIG_SATA_VIA=y
CONFIG_ATA_PIIX=y                  # Intel PIIX/ICH SATA/IDE (VirtualBox, QEMU, most PCs)
CONFIG_ATA_GENERIC=y               # Generic ATA driver (fallback)
CONFIG_PATA_AMD=y
CONFIG_PATA_ATIIXP=y
CONFIG_PATA_JMICRON=y
CONFIG_PATA_MARVELL=y
