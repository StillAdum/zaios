# ─────────────────────────────────────────────────────────────────────────────
# ZAIos Linux kernel configuration — common to all arches.
# This file is concatenated with arch-specific fragments (zaios_<arch>.config)
# by build.sh before `make olddefconfig`.
#
# Design goals:
#   * Boot on any TV box / mini-PC / Raspberry Pi
#   * Built-in drivers for: GPU (Intel/AMD/NVIDIA-open), WiFi (all mainline
#     chipsets), Bluetooth, audio (HDMI + USB + I2S), input (evdev, HID),
#     storage (SATA, NVMe, USB, eMMC, SDIO)
#   * Wayland / DRM / KMS for the Cage kiosk compositor
#   * zram for swap, squashfs + overlayfs for the live ISO
#   * Network: full TCP/IP + IPv6 + WiFi + Bluetooth + ConnMan/iwd
#   * No legacy ISA / MCA / PCMCIA / AMIGA — keep image lean
# ─────────────────────────────────────────────────────────────────────────────

# ── Local version ─────────────────────────────────────────────────────────────
CONFIG_LOCALVERSION="-zaios-1.0"
CONFIG_LOCALVERSION_AUTO=n

# ── 64-bit / multilib on x86_64 ───────────────────────────────────────────────
CONFIG_64BIT=y

# ── Wayland / DRM / KMS / GPU ─────────────────────────────────────────────────
CONFIG_DRM=y
CONFIG_DRM_KMS_HELPER=y
CONFIG_DRM_FBDEV_EMULATION=y
CONFIG_DRM_LOAD_EDID_FIRMWARE=y
CONFIG_DRM_DP_AUX_CHARDEV=y
CONFIG_DRM_DEBUG_MODESET_CODEC=n

# GPU drivers — built-in so the UI starts without module loading
CONFIG_DRM_I915=y                # Intel
CONFIG_DRM_AMDGPU=y              # AMD
CONFIG_DRM_NOUVEAU=y             # NVIDIA (open)
CONFIG_DRM_RADEON=y              # AMD/ATI legacy
CONFIG_DRM_UDL=y                 # DisplayLink USB
CONFIG_DRM_VIRTIO_GPU=y          # QEMU virt
CONFIG_DRM_VBOXVIDEO=y           # VirtualBox graphics (critical for VBox VMs)
CONFIG_DRM_VKMS=y                # Virtual Kernel Mode Setting (fallback for any VM)
CONFIG_DRM_VMGM=y                # VMware (not a real config, but try)
CONFIG_DRM_VC4=y                 # Raspberry Pi 4/5 (BCM2711/2712)
CONFIG_DRM_V3D=y                 # Raspberry Pi V3D
CONFIG_DRM_PANEL_SIMPLE=y
CONFIG_DRM_PANEL_EDP=y
CONFIG_DRM_PANEL_BRIDGE=y
CONFIG_DRM_BRIDGE=y
CONFIG_DRM_HDMI=y
CONFIG_FB=y
CONFIG_FB_VESA=y
CONFIG_FB_EFI=y
CONFIG_FB_SIMPLE=y
CONFIG_FRAMEBUFFER_CONSOLE=y
CONFIG_FRAMEBUFFER_CONSOLE_DETECT_PRIMARY=y

