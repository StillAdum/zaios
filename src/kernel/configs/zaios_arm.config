# ZAIos kernel config — ARM32 (ARMv7) — Raspberry Pi 2/3, etc.
# Inherits from zaios_common.config (concatenated by build.sh)

# ── 32-bit ARM ───────────────────────────────────────────────────────────────
CONFIG_ARM=y
CONFIG_ARM_HAS_SG_CHAIN=y
CONFIG_MMU=y
CONFIG_ARCH_MULTI_V7=y
CONFIG_ARCH_MULTI_V6_V7=y
CONFIG_ARCH_MULTI_V7=y
CONFIG_NR_CPUS=4
CONFIG_HOTPLUG_CPU=y
CONFIG_ARM_THUMB=y
CONFIG_ARM_THUMBEE=y
CONFIG_AEABI=y
CONFIG_OABI_COMPAT=y
CONFIG_HIGHMEM=y
CONFIG_CPU_V7=y
CONFIG_CPU_32v6K=y
CONFIG_CPU_32v7=y
CONFIG_CPU_ABRT_EV7=y
CONFIG_CPU_PABRT_V7=y
CONFIG_CPU_CACHE_VIPT=y
CONFIG_CPU_CACHE_V7=y
CONFIG_CPU_COPY_V6=y
CONFIG_CPU_TLB_V7=y
CONFIG_CPU_HAS_ASID=y
CONFIG_CPU_CP15=y
CONFIG_CPU_CP15_MMU=y

# ── CPUFreq ──────────────────────────────────────────────────────────────────
CONFIG_CPU_FREQ=y
CONFIG_CPU_FREQ_DEFAULT_GOV_SCHEDUTIL=y
CONFIG_CPU_FREQ_GOV_ONDEMAND=y
CONFIG_CPU_FREQ_GOV_SCHEDUTIL=y
CONFIG_ARM_BCM2835_CPUFREQ=y

# ── Raspberry Pi 2/3 ─────────────────────────────────────────────────────────
CONFIG_ARCH_BCM=y
CONFIG_ARCH_BCM2835=y
CONFIG_BCM2835_MBOX=y
CONFIG_RASPBERRYPI_FIRMWARE=y
CONFIG_RASPBERRYPI_POWER=y
CONFIG_BCM2835_TIMER=y
CONFIG_BCM2835_WDT=y
CONFIG_HW_RANDOM_BCM2835=y
CONFIG_BCM2835_VCHIQ=y

# ── Other popular 32-bit boards ──────────────────────────────────────────────
CONFIG_ARCH_SUNXI=y                    # Allwinner (lots of TV boxes)
CONFIG_ARCH_ROCKCHIP=y                 # RK3288-based TV sticks
CONFIG_ARCH_MESON=y                    # Amlogic Meson8/8b
CONFIG_ARCH_TEGRA=y                    # Tegra 30/124
CONFIG_ARCH_OMAP3=y
CONFIG_ARCH_OMAP4=y
CONFIG_ARCH_QCOM=y                     # older Snapdragon

# ── DRM / GPU for 32-bit ARM ─────────────────────────────────────────────────
CONFIG_DRM_VC4=y                       # Pi 2/3 GPU
CONFIG_DRM_LIMA=y                      # Mali-4xx
CONFIG_DRM_PANFROST=y                  # Mali Midgard
CONFIG_DRM_MSM=y                       # Adreno
CONFIG_DRM_PANEL_ILITEK_ILI9881C=y
CONFIG_DRM_PANEL_RASPBERRYPI_TOUCHSCREEN=y
CONFIG_DRM_SIMPLE_BRIDGE=y
CONFIG_DRM_PANEL_SIMPLE=y

# ── PCI on 32-bit ARM ────────────────────────────────────────────────────────
CONFIG_PCI=y
CONFIG_PCI_MSI=y
CONFIG_PCI_HOST_GENERIC=y
CONFIG_PCIE_DW=y
CONFIG_PCIE_DW_HOST=y
CONFIG_PCIEPORTBUS=y

# ── DMA / IOMMU on ARM32 ─────────────────────────────────────────────────────
CONFIG_ARM_DMA_USE_IOMMU=y
CONFIG_IOMMU_SUPPORT=y
CONFIG_OMAP_IOMMU=y
CONFIG_ROCKCHIP_IOMMU=y

# ── Clocksource ──────────────────────────────────────────────────────────────
CONFIG_ARM_ARCH_TIMER=y
CONFIG_ARM_ARCH_TIMER_EVTSTREAM=y
CONFIG_ARM_GLOBAL_TIMER=y
CONFIG_CLKSRC_MMIO=y
CONFIG_DW_APB_TIMER=y

# ── Thermal ──────────────────────────────────────────────────────────────────
CONFIG_THERMAL=y
CONFIG_THERMAL_OF=y
CONFIG_CPU_THERMAL=y
CONFIG_BCM2835_THERMAL=y
CONFIG_ROCKCHIP_THERMAL=y
CONFIG_SUN8I_THERMAL=y
CONFIG_WATCHDOG=y
CONFIG_WATCHDOG_NOWAYOUT=y
CONFIG_BCM2835_WDT=y
CONFIG_SUNXI_WATCHDOG=y
CONFIG_DW_WATCHDOG=y

# ── Floating point / NEON ────────────────────────────────────────────────────
CONFIG_VFP=y
CONFIG_VFPv3=y
CONFIG_NEON=y
CONFIG_KERNEL_MODE_NEON=y

# ── Real-time clock ──────────────────────────────────────────────────────────
CONFIG_RTC_CLASS=y
CONFIG_RTC_DRV_DS1307=y
CONFIG_RTC_DRV_PCF8523=y
CONFIG_RTC_DRV_RV3028=y
CONFIG_RTC_DRV_RV8803=y

# ── LED / GPIO drivers ──────────────────────────────────────────────────────
CONFIG_LEDS_CLASS=y
CONFIG_LEDS_GPIO=y
CONFIG_LEDS_PWM=y
CONFIG_LEDS_TRIGGERS=y
CONFIG_LEDS_TRIGGER_TIMER=y
CONFIG_LEDS_TRIGGER_HEARTBEAT=y
CONFIG_LEDS_TRIGGER_DEFAULT_ON=y
